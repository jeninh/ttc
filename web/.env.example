# Google Gemini API key for AI-powered alert analysis & relative directions
# Get one at https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=

# Google Maps API key for landmark-based relative directions (optional)
# Enable Places API (New) at https://console.cloud.google.com/apis
# Without this key, relative directions still work but without landmark references
VITE_GOOGLE_MAPS_API_KEY=
